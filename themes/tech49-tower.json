  "semanticTokenColors": {
    "namespace": "#76cddc",
    "class": "#d9fefd",
    "class.declaration": { "foreground": "#d9fefd", "fontStyle": "bold" },
    "interface": "#d9fefd",
    "enum": "#ff815c",
    "enumMember": "#ff815c",
    "struct": "#d9fefd",
    "type": "#d9fefd",
    "typeParameter": "#9ea485",
    "function": { "foreground": "#78cfde", "fontStyle": "italic" },
    "method": { "foreground": "#78cfde", "fontStyle": "italic" },
    "macro": "#78cfde",
    "variable": "#accecb",
    "variable.readonly": "#76cddc",
    "variable.declaration": "#fefedb",
    "parameter": "#ff815c",
    "property": "#accecb",
    "property.readonly": "#76cddc",
    "keyword": "#d1dbaf",
    "string": "#9ea485",
    "number": "#ff815c",
    "regexp": "#fefedb",
    "operator": "#78cfde",
    "decorator": "#ff815c",
    "*.deprecated": { "fontStyle": "strikethrough" }
  },
  "tokenColors": [
    {
      "settings": {
        "foreground": "#accecbff",
        "background": "#03070aff"
      }
    },
    {
      "name": "Comment",
      "scope": "comment",
      "settings": {
        "foreground": "#396269"
      }
    },
    {
      "name": "Foreground",
      "scope": "keyword.operator.class, constant.other, source.php.embedded.line",
      "settings": {
        "fontStyle": "",
        "foreground": "#76cddc"
      }
    },
    {
      "name": "Variable, String Link, Regular Expression",
      "scope": "variable, support.other.variable, string.other.link, string.regexp, entity.other.attribute-name",
      "settings": {
        "fontStyle": "",
        "foreground": "#fefedb"
      }
    },
    {
      "name": "this.self",
      "scope": "variable.language",
      "settings": {
        "foreground": "#accecb"
      }
    },
    {
      "name": "Number, Constant, Function Argument, Embedded, Tag Name",
      "scope": "constant.numeric, entity.name.tag, meta.tag, declaration.tag, constant.language, support.constant, constant.character, variable.parameter, punctuation.section.embedded, keyword.other.unit",
      "settings": {
        "fontStyle": "",
        "foreground": "#ff815c"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": "meta.tag",
      "settings": {
        "fontStyle": "",
        "foreground": "#accecb"
      }
    },
    {
      "name": "Class, Support",
      "scope": "entity.name.class, entity.name.type.class, support.type, support.class",
      "settings": {
        "fontStyle": "normal",
        "foreground": "#d9fefd"
      }
    },
    {
      "name": "String, Symbols, Inherited Class, Markup Heading",
      "scope": "string, constant.other.symbol, entity.other.inherited-class, markup.heading",
      "settings": {
        "fontStyle": "",
        "foreground": "#9ea485"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": "keyword.operator, constant.other.color",
      "settings": {
        "foreground": "#78cfde"
      }
    },
    {
      "name": "Function, Special Method, Block Level",
      "scope": "entity.name.function, meta.function-call, support.function, keyword.other.special-method, meta.block-level",
